{
  "manifest_version": 3,
  "name": "图片预览器",
  "version": "0.1.0",
  "description": "右键查看图片，弹窗预览，支持缩放与旋转。",
  "permissions": ["contextMenus", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"],
      "all_frames": true,
      "match_about_blank": true,
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "图片预览器"
  }
}
